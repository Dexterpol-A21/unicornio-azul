---
import SEO from '@components/global/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <SEO {title} {description} />
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>
